# Client-side app config
# Example company/product: Acme Corp / Atlas
SHIPYARD_BASE_URL=https://acme-studio.startshipyard.com
SHIPYARD_PRODUCT_SLUG=atlas
SHIPYARD_PLATFORM=ios

# Values resolved at runtime
# - installationId: stable per-install identifier
# - appVersion/buildNumber: optional but recommended

# Server requirements set on Shipyard backend, not in app
# SESSION_SECRET=...
# Product engagement must be enabled in Shipyard.
